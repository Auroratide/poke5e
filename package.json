{
	"name": "poke5e",
	"version": "1.11.0",
	"scripts": {
		"start": "vite preview",
		"dev": "vite dev",
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"clean": "rm -rf build",
		"ci": "npm-run-all clean check build",
		"gh": "gh-pages -d build --dotfiles",
		"publish": "npm-run-all ci gh",
		"script:get-pokemon-images": "node ./scripts/get-pokemon-images.js",
		"script:create-pokemon": "node ./scripts/create-pokemon.js",
		"test": "vitest run",
		"test:unit": "vitest run src",
		"test:functions": "deno run -A supabase/functions/test.ts",
		"test:smoke": "playwright test",
		"test:smoke:debug": "playwright test --headed",
		"test:smoke:report": "playwright show-report",
		"test:db": "supabase db reset && vitest run test/db/*.test.ts",
		"test:db:quick": "vitest run test/db/*.test.ts",
		"lint": "eslint src",
		"services:start": "supabase start && docker compose up -d",
		"services:stop": "supabase stop && docker compose down",
		"machine-translate": "inlang machine translate --project project.inlang"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@inlang/cli": "^3.1.9",
		"@inlang/paraglide-js": "^2.16.0",
		"@playwright/test": "1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@types/node": "^24.12.2",
		"@types/pg": "^8.20.0",
		"@vitest/browser": "^3.2.4",
		"cheerio": "^1.2.0",
		"chromium-bidi": "^13.1.1",
		"csv-parse": "^6.2.1",
		"dotenv": "^16.6.1",
		"eslint": "^9.39.4",
		"eslint-plugin-only-error": "^1.0.2",
		"eslint-plugin-svelte": "^3.17.1",
		"gh-pages": "^3.2.3",
		"globals": "^16.5.0",
		"mdsvex": "^0.12.7",
		"npm-run-all": "^4.1.5",
		"pg": "^8.20.0",
		"playwright": "^1.59.1",
		"postgres-migrations": "^5.3.0",
		"supabase": "^2.93.0",
		"svelte": "^4.2.20",
		"svelte-check": "^3.8.6",
		"svelte-preprocess": "^5.1.4",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^5.4.21",
		"vitest": "^3.2.4"
	},
	"type": "module",
	"license": "ISC",
	"author": {
		"name": "Timothy Foster",
		"url": "https://auroratide.com"
	},
	"dependencies": {
		"@auroratide/pokemon-types": "^0.1.0",
		"@auroratide/reorder-list": "^0.5.1",
		"@auroratide/tab-list": "^0.2.6",
		"@auroratide/toggle-switch": "^0.3.1",
		"@floating-ui/dom": "^1.7.6",
		"@supabase/supabase-js": "^2.104.0",
		"dompurify": "^3.4.1",
		"marked": "^15.0.12"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"pnpm": "^10.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"puppeteer",
			"supabase",
			"svelte-preprocess",
			"taiko"
		]
	}
}
